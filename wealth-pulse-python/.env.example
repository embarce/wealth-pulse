# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wealth_pulse

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_data_center
REDIS_DB=0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
API_CLIENT_ID=wealth-pulse-java
API_CLIENT_SECRET=wealth-pulse-client-secret

# Task Scheduling
SCHEDULER_ENABLED=true
MARKET_DATA_UPDATE_INTERVAL=300  # seconds (5 minutes)

# Logging
LOG_LEVEL=INFO

AUTO_INIT_STOCKS=true  # 启用，快速导入数据