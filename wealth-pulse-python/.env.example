# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=embrace_data_center
DB_NAME=wealth_pulse

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_data_center
REDIS_DB=0

# API
API_HOST=127.0.0.1
API_PORT=8010
API_RELOAD=true
API_SECRET_KEY=your-secret-key-change-this-in-production
API_CLIENT_ID=wealth-pulse-java
API_CLIENT_SECRET=wealth-pulse-client-secret

# Task Scheduling
SCHEDULER_ENABLED=true
MARKET_DATA_UPDATE_INTERVAL=300  # seconds (5 minutes)

# Logging
LOG_LEVEL=INFO

# Stock Data Provider
STOCK_DATA_PROVIDER=akshare  # Options: 'akshare' (default, 港股专用), 'yfinance' (全球市场)
# - akshare: 港股专用数据 API，使用新浪财经接口，速度极快（推荐用于港股，速度提升 10-30 倍）
# - yfinance: Yahoo Finance API（支持全球股票：港股 + 美股+A 股，适合多市场）

AUTO_INIT_STOCKS=true  # 启用，快速导入数据

# ==================== LLM Configuration ====================
# 默认供应商（可选：doubao, openai, qwen, gemini, gitee, anthropic, deepseek, zhipu）
LLM_PROVIDER=gitee

# ---------- 豆包 (火山引擎) ----------
# 获取 API Key: https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=ep-20250226185244-dxp9w
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_TOP_P=0.9
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128

# ---------- OpenAI ----------
# 获取 API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini  # 可选：gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- Anthropic (Claude) ----------
# 获取 API Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # 可选：claude-3-5-sonnet, claude-3-5-haiku, claude-3-opus
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------- Qwen (阿里云通义千问) ----------
# 获取 API Key: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo  # 可选：qwen-turbo, qwen-plus, qwen-max, qwen-long
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TOP_P=0.8

# ---------- Gemini (Google) ----------
# 获取 API Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash  # 可选：gemini-pro, gemini-1.5-pro, gemini-2.0-flash
# GEMINI_BASE_URL=  # 可选，自定义 API 端点

# ---------- Gitee AI ----------
# 获取 API Key: https://ai.gitee.com/
GITEE_API_KEY=your_gitee_api_key_here
GITEE_MODEL=Qwen2.5-72B-Instruct  # 可选：Qwen2.5-72B-Instruct, Qwen3-235B-A22B
GITEE_BASE_URL=https://ai.gitee.com/v1

# ---------- DeepSeek (深度求索) ----------
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat  # 可选：deepseek-chat, deepseek-coder, deepseek-v3
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- ZhipuAI (智谱 AI) ----------
# 获取 API Key: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4  # 可选：glm-4, glm-4-air, glm-4-flash, glm-3-turbo
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
